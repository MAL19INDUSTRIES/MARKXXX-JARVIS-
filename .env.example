# Copy this file to .env and fill in your values locally.
# Never commit .env to GitHub.

# Required for Google Gemini Live
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Optional: choose from SUPPORTED_VOICE_NAMES in main.py (case-insensitive)
# Example: puck, charon, kore, fenrir, aoede, leda, orus, schedar, zubenelgenubi
GEMINI_VOICE_NAME="puck"

# Optional: trial/keyword runtime limit
# If JARVIS_TRIAL_KEYWORD is set to any non-empty string,
# Jarvis will run for JARVIS_RUNTIME_SECONDS (default: 3600).
#JARVIS_TRIAL_KEYWORD="trial"
#JARVIS_RUNTIME_SECONDS="3600"

# Optional: locked container requirements
#JARVIS_LOCKED_KEY_SECRET="expected_unlock_key_contents"
#JARVIS_LOCKED_VOLUME="NameOfVolumeUnderVolumes"

# Optional: for the local API (if you enable api.server)
#JARVIS_API_KEY="YOUR_PRIVATE_API_KEY"

